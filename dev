#!/bin/bash

# One-command local launcher. Datasource credentials stay in process memory and
# are read from the repository-local Supabase CLI instead of files or arguments.
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND_DIR="$ROOT_DIR/backend/ordersystem"
COMMAND="${1:-start}"
SUPABASE_STARTED_BY_LAUNCHER=false
READINESS_PID=""
APP_PID=""

info() {
  printf '[dev] %s\n' "$*"
}

fail() {
  printf '[dev] error: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "Required command '$1' was not found."
}

configure_java() {
  if [[ "$(uname -s)" == "Darwin" && -x /usr/libexec/java_home ]]; then
    local java_home
    java_home="$(/usr/libexec/java_home -v 21 2>/dev/null || true)"
    if [[ -n "$java_home" ]]; then
      export JAVA_HOME="$java_home"
      export PATH="$JAVA_HOME/bin:$PATH"
    fi
  fi

  require_command java
  local java_major
  java_major="$(java -XshowSettings:properties -version 2>&1 | awk -F'= ' '/java.specification.version/ { print $2; exit }')"
  [[ "$java_major" == "21" ]] || fail "Java 21 is required; found Java ${java_major:-unknown}."
}

ensure_docker() {
  require_command docker
  if docker info >/dev/null 2>&1; then
    info "Docker is ready."
    return
  fi

  if [[ "$(uname -s)" != "Darwin" || ! -x /usr/bin/open ]]; then
    fail "Docker is not running. Start Docker, then run ./dev again."
  fi

  info "Starting Docker Desktop..."
  /usr/bin/open -a Docker || fail "Docker Desktop could not be opened."

  local timeout="${DOCKER_START_TIMEOUT_SECONDS:-120}"
  [[ "$timeout" =~ ^[0-9]+$ ]] && (( timeout > 0 )) || \
    fail "DOCKER_START_TIMEOUT_SECONDS must be a positive integer."
  local elapsed=0
  while ! docker info >/dev/null 2>&1; do
    if (( elapsed >= timeout )); then
      fail "Docker did not become ready within ${timeout} seconds."
    fi
    sleep 1
    ((elapsed += 1))
  done
  info "Docker is ready."
}

supabase_is_running() {
  supabase status --workdir "$ROOT_DIR" >/dev/null 2>&1
}

ensure_supabase() {
  require_command supabase
  if supabase_is_running; then
    info "Local Supabase is already running; it will be left running on exit."
    return
  fi

  SUPABASE_STARTED_BY_LAUNCHER=true
  info "Starting local Supabase..."
  if ! supabase start --workdir "$ROOT_DIR" >/dev/null 2>&1; then
    fail "Run 'supabase start --workdir \"$ROOT_DIR\"' for full diagnostics."
  fi
  info "Local Supabase is ready."
}

read_datasource() {
  local status_output db_url connection_details credentials host_and_path
  status_output="$(supabase status --workdir "$ROOT_DIR" -o env 2>/dev/null)" || \
    fail "Could not read the local Supabase connection details."

  db_url=""
  while IFS='=' read -r key value; do
    if [[ "$key" == "DB_URL" ]]; then
      db_url="$value"
      break
    fi
  done <<< "$status_output"
  unset status_output

  db_url="${db_url#\"}"
  db_url="${db_url%\"}"
  [[ "$db_url" == postgresql://*:*@*/* ]] || \
    fail "Supabase returned an unsupported local database URL."

  connection_details="${db_url#postgresql://}"
  credentials="${connection_details%%@*}"
  host_and_path="${connection_details#*@}"

  export SPRING_DATASOURCE_USERNAME="${credentials%%:*}"
  export SPRING_DATASOURCE_PASSWORD="${credentials#*:}"
  export SPRING_DATASOURCE_URL="jdbc:postgresql://${host_and_path}"
  unset db_url connection_details credentials host_and_path
}

report_readiness() {
  local port="${SERVER_PORT:-8080}"
  local attempt
  for ((attempt = 0; attempt < 90; attempt += 1)); do
    if curl --silent --show-error --fail \
      --connect-timeout 1 --max-time 2 \
      "http://127.0.0.1:${port}/actuator/health/readiness" >/dev/null 2>&1; then
      info "Application is ready: http://127.0.0.1:${port}"
      return
    fi
    sleep 1
  done
  printf '[dev] warning: readiness did not become healthy within 90 seconds.\n' >&2
}

cleanup() {
  local status=$?
  trap - EXIT INT TERM

  if [[ -n "$APP_PID" ]] && kill -0 "$APP_PID" >/dev/null 2>&1; then
    kill -TERM "-$APP_PID" >/dev/null 2>&1 || kill -TERM "$APP_PID" >/dev/null 2>&1 || true
    local attempt=0
    while kill -0 "$APP_PID" >/dev/null 2>&1 && (( attempt < 20 )); do
      sleep 0.25
      ((attempt += 1))
    done
    if kill -0 "$APP_PID" >/dev/null 2>&1; then
      kill -KILL "-$APP_PID" >/dev/null 2>&1 || kill -KILL "$APP_PID" >/dev/null 2>&1 || true
    fi
    wait "$APP_PID" 2>/dev/null || true
  fi
  if [[ -n "$READINESS_PID" ]]; then
    kill "$READINESS_PID" >/dev/null 2>&1 || true
    wait "$READINESS_PID" 2>/dev/null || true
  fi
  if [[ "$SUPABASE_STARTED_BY_LAUNCHER" == "true" ]]; then
    info "Stopping launcher-owned Supabase..."
    supabase stop --workdir "$ROOT_DIR" >/dev/null 2>&1 || \
      printf '[dev] warning: Supabase did not stop cleanly; run ./dev stop.\n' >&2
  fi
  exit "$status"
}

start_application() {
  trap cleanup EXIT
  trap 'exit 130' INT
  trap 'exit 143' TERM

  configure_java
  require_command curl
  [[ -x "$BACKEND_DIR/mvnw" ]] || fail "Maven Wrapper is missing or not executable."

  local port="${SERVER_PORT:-8080}"
  [[ "$port" =~ ^[0-9]+$ ]] && (( port > 0 && port <= 65535 )) || \
    fail "SERVER_PORT must be an integer from 1 through 65535."
  if command -v lsof >/dev/null 2>&1 && \
    lsof -nP -iTCP:"$port" -sTCP:LISTEN -t >/dev/null 2>&1; then
    fail "Port $port is already in use. Set SERVER_PORT to another port or stop the existing process."
  fi

  ensure_docker
  ensure_supabase
  read_datasource

  info "Starting the application with Java 21 (scheduler=${ORDERS_SCHEDULER_ENABLED:-true})..."
  report_readiness &
  READINESS_PID=$!

  # A dedicated process group lets INT/TERM cleanup stop Maven and its Spring
  # child together without leaving an orphaned application process.
  set -m
  (
    cd "$BACKEND_DIR"
    exec ./mvnw spring-boot:run
  ) &
  APP_PID=$!
  set +m

  set +e
  wait "$APP_PID"
  local app_status=$?
  set -e
  APP_PID=""
  return "$app_status"
}

stop_supabase() {
  require_command supabase
  if ! command -v docker >/dev/null 2>&1 || ! docker info >/dev/null 2>&1; then
    info "Docker is not running; local Supabase is already stopped."
    return
  fi
  if ! supabase_is_running; then
    info "Local Supabase is already stopped."
    return
  fi
  supabase stop --workdir "$ROOT_DIR" >/dev/null 2>&1
  info "Local Supabase stopped."
}

show_status() {
  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    info "Docker: ready"
  else
    info "Docker: stopped"
  fi

  if command -v supabase >/dev/null 2>&1 && supabase_is_running; then
    info "Supabase: ready"
  else
    info "Supabase: stopped"
  fi

  local port="${SERVER_PORT:-8080}"
  if command -v curl >/dev/null 2>&1 && \
    curl --silent --fail --connect-timeout 1 --max-time 2 \
      "http://127.0.0.1:${port}/actuator/health/readiness" >/dev/null 2>&1; then
    info "Application: ready at http://127.0.0.1:${port}"
  else
    info "Application: stopped or not ready"
  fi
}

show_help() {
  cat <<'EOF'
Usage:
  ./dev          Start Docker/Supabase as needed and run the application
  ./dev status   Show Docker, Supabase, and application readiness
  ./dev stop     Stop the repository-local Supabase project
  ./dev help     Show this help

Optional environment variables:
  SERVER_PORT=8081                 Override the HTTP port
  ORDERS_SCHEDULER_ENABLED=false   Disable automatic order processing
  DOCKER_START_TIMEOUT_SECONDS=120 Docker Desktop startup timeout
EOF
}

case "$COMMAND" in
  start)
    start_application
    ;;
  status)
    show_status
    ;;
  stop)
    stop_supabase
    ;;
  help|-h|--help)
    show_help
    ;;
  *)
    show_help >&2
    fail "Unknown command '$COMMAND'."
    ;;
esac
