{
  "info": {
    "_postman_id": "73459ab0-b438-4b22-bb90-03e2de3687e8",
    "name": "Order Processing Local Smoke",
    "description": "Credential-free local smoke for the V1 API and health/readiness endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://127.0.0.1:8080"},
    {"key": "orderId", "value": ""},
    {"key": "cancelOrderId", "value": ""}
  ],
  "item": [
    {
      "name": "Health",
      "request": {"method": "GET", "url": "{{baseUrl}}/actuator/health"},
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('health is UP', function () {",
        "  pm.response.to.have.status(200);",
        "  pm.expect(pm.response.json().status).to.eql('UP');",
        "});"
      ]}}]
    },
    {
      "name": "Database readiness",
      "request": {"method": "GET", "url": "{{baseUrl}}/actuator/health/readiness"},
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('database readiness is UP', function () {",
        "  pm.response.to.have.status(200);",
        "  pm.expect(pm.response.json().status).to.eql('UP');",
        "});"
      ]}}]
    },
    {
      "name": "Create fulfilment order",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\n  \"items\": [\n    {\"productId\": \"SMOKE-RED\", \"quantity\": 2},\n    {\"productId\": \"SMOKE-BLUE\", \"quantity\": 1}\n  ]\n}"},
        "url": "{{baseUrl}}/api/v1/orders"
      },
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('order is created pending', function () {",
        "  pm.response.to.have.status(201);",
        "  const body = pm.response.json();",
        "  pm.expect(body.status).to.eql('PENDING');",
        "  pm.expect(body.items).to.have.length(2);",
        "  pm.collectionVariables.set('orderId', body.id);",
        "  pm.expect(pm.response.headers.get('Location')).to.eql('/api/v1/orders/' + body.id);",
        "});"
      ]}}]
    },
    {
      "name": "Retrieve order",
      "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/orders/{{orderId}}"},
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('detail preserves submitted item order', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.id).to.eql(pm.collectionVariables.get('orderId'));",
        "  pm.expect(body.items.map(item => item.productId)).to.eql(['SMOKE-RED', 'SMOKE-BLUE']);",
        "});"
      ]}}]
    },
    {
      "name": "List pending orders",
      "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/orders?status=PENDING&page=0&size=20&sort=ignored"},
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('list accepts filter and ignores undocumented sort', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.content.some(order => order.id === pm.collectionVariables.get('orderId'))).to.be.true;",
        "});"
      ]}}]
    },
    {
      "name": "Advance to processing",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"status\":\"PROCESSING\"}"},
        "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/status"
      },
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('pending advances to processing', function () {",
        "  pm.response.to.have.status(200);",
        "  pm.expect(pm.response.json().status).to.eql('PROCESSING');",
        "});"
      ]}}]
    },
    {
      "name": "Advance to shipped",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"status\":\"SHIPPED\"}"},
        "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/status"
      },
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('processing advances to shipped', function () {",
        "  pm.response.to.have.status(200);",
        "  pm.expect(pm.response.json().status).to.eql('SHIPPED');",
        "});"
      ]}}]
    },
    {
      "name": "Advance to delivered",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"status\":\"DELIVERED\"}"},
        "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/status"
      },
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('shipped advances to delivered', function () {",
        "  pm.response.to.have.status(200);",
        "  pm.expect(pm.response.json().status).to.eql('DELIVERED');",
        "});"
      ]}}]
    },
    {
      "name": "Create cancellable order",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"items\":[{\"productId\":\"SMOKE-CANCEL\",\"quantity\":1}]}"},
        "url": "{{baseUrl}}/api/v1/orders"
      },
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('second order is created', function () {",
        "  pm.response.to.have.status(201);",
        "  pm.collectionVariables.set('cancelOrderId', pm.response.json().id);",
        "});"
      ]}}]
    },
    {
      "name": "Cancel pending order",
      "request": {"method": "POST", "url": "{{baseUrl}}/api/v1/orders/{{cancelOrderId}}/cancel"},
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('pending order is cancelled', function () {",
        "  pm.response.to.have.status(200);",
        "  pm.expect(pm.response.json().status).to.eql('CANCELLED');",
        "});"
      ]}}]
    },
    {
      "name": "Repeat cancellation conflict",
      "request": {"method": "POST", "url": "{{baseUrl}}/api/v1/orders/{{cancelOrderId}}/cancel"},
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('repeat cancellation is a stable conflict', function () {",
        "  pm.response.to.have.status(409);",
        "  const body = pm.response.json();",
        "  pm.expect(body.code).to.eql('ORDER_STATE_CONFLICT');",
        "  pm.expect(body).to.have.all.keys('type', 'title', 'status', 'detail', 'instance', 'code', 'traceId', 'violations');",
        "});"
      ]}}]
    },
    {
      "name": "Reject unknown create field",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"items\":[{\"productId\":\"INVALID\",\"quantity\":1}],\"status\":\"SHIPPED\"}"},
        "url": "{{baseUrl}}/api/v1/orders"
      },
      "event": [{"listen": "test", "script": {"exec": [
        "pm.test('server-owned field is rejected', function () {",
        "  pm.response.to.have.status(400);",
        "  pm.expect(pm.response.json().code).to.eql('INVALID_REQUEST');",
        "});"
      ]}}]
    }
  ]
}
